{
  "name": "@rappi-ds/react",
  "version": "0.1.0",
  "description": "React component library for the Rappi Design System",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rappi/design-system-rappi.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/rappi/design-system-rappi#readme",
  "bugs": {
    "url": "https://github.com/rappi/design-system-rappi/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@rappi-ds/icons": "workspace:*",
    "@rappi-ds/tokens": "workspace:*",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^26.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
